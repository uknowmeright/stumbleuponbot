# stumbleupon pipeline configuration
# Copy to .env and fill in real values. .env is gitignored.

# Claude API (for captioner)
ANTHROPIC_API_KEY=

# Buffer API (for poster)
BUFFER_API_KEY=

# Cloudflare R2 (for video hosting, S3-compatible)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# R2 API endpoint (S3-compatible). Find it in the Cloudflare dashboard:
#   R2 → <bucket> → Settings → S3 API endpoint. Typically
#   https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=
# Public CDN URL where uploaded clips are served (the URL Buffer will link to).
# Distinct from R2_ENDPOINT_URL above.
R2_PUBLIC_URL_BASE=

# Optional: OpenAI (for Whisper captions — deferred to future plan)
# OPENAI_API_KEY=

# Optional: residential proxy for TikTok trending sounds scrape
# PROXY_URL=

# Comma-separated ad-block keywords filtered during scraping
AD_BLOCK_KEYWORDS=nsfw,adult,xxx,porn

# Pipeline tunables
PIPELINE_DAILY_RUNS=2
PIPELINE_RUN_TIMES=10:00,20:00
POSTS_PER_DAY=2

# stumbleupon.cc public Supabase API (anon key is public — embedded in their JS bundle)
STUMBLEUPON_API_URL=https://boembmgwjjdqgkcokapx.supabase.co/rest/v1/sites
STUMBLEUPON_API_KEY=
